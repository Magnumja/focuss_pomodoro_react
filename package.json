{
    "name":  "focuss-pomodoro",
    "private":  true,
    "version":  "0.0.0",
    "description":  "Timer Pomodoro desktop e web para sessões de foco.",
    "author":  "Magnumja",
    "type":  "module",
    "main":  "electron/main.cjs",
    "scripts":  {
                    "dev":  "vite",
                    "build":  "tsc -b \u0026\u0026 vite build",
                    "desktop":  "npm run build \u0026\u0026 electron .",
                    "build:exe":  "npm run build \u0026\u0026 electron-builder --win portable --x64",
                    "lint":  "eslint .",
                    "preview":  "vite preview"
                },
    "build":  {
                  "appId":  "com.magnumja.focusspomodoro",
                  "productName":  "Focuss Pomodoro",
                  "directories":  {
                                      "output":  "release"
                                  },
                  "files":  [
                                "dist/**/*",
                                "electron/**/*",
                                "package.json"
                            ],
                  "win":  {
                              "signAndEditExecutable":  false,
                              "target":  [
                                             "portable"
                                         ]
                          }
              },
    "dependencies":  {
                         "react":  "^19.2.0",
                         "react-dom":  "^19.2.0"
                     },
    "devDependencies":  {
                            "@eslint/js":  "^9.39.1",
                            "@types/node":  "^24.10.1",
                            "@types/react":  "^19.2.5",
                            "@types/react-dom":  "^19.2.3",
                            "@vitejs/plugin-react-swc":  "^4.2.2",
                            "electron":  "^41.5.0",
                            "electron-builder":  "^26.8.1",
                            "eslint":  "^9.39.1",
                            "eslint-plugin-react-hooks":  "^7.0.1",
                            "eslint-plugin-react-refresh":  "^0.4.24",
                            "globals":  "^16.5.0",
                            "typescript":  "~5.9.3",
                            "typescript-eslint":  "^8.46.4",
                            "vite":  "^7.2.4"
                        }
}
